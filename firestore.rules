rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Profiles collection rules
    match /profiles/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100
        && request.resource.data.gender in ['Laki-laki', 'Perempuan']
        && request.resource.data.weight is number
        && request.resource.data.weight >= 1
        && request.resource.data.weight <= 500
        && request.resource.data.height is number
        && request.resource.data.height >= 10
        && request.resource.data.height <= 300
        && request.resource.data.bmi is number
        && request.resource.data.bmiCategory is string
        && request.resource.data.totalLogins is int
        && request.resource.data.totalLogins >= 0;
    }

    // Blood Pressures collection rules
    match /bloodPressures/{bpId} {
      allow read, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.systolic is number
        && request.resource.data.systolic >= 30
        && request.resource.data.systolic <= 300
        && request.resource.data.diastolic is number
        && request.resource.data.diastolic >= 10
        && request.resource.data.diastolic <= 200
        && request.resource.data.category is string
        && request.resource.data.createdAt == request.time;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
